.Python
# Single-venv convention: the project uses exactly one venv at python/.venv
# (enforced by tools/check_venv_convention.py). No root or alternately-named
# venvs — a stray one should surface in `git status`, not be silently ignored.
.venv
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
*.egg-info/
dist/
build/

# Shake
.shake/
.shake.database

