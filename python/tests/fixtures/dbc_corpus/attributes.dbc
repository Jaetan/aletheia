BA_ "MsgCycleTime" BO_ 400 50;
BA_ "SignalPriority" SG_ 400 Value 2;
BA_ "EnvVarScaling" EV_ Monitor 16;
BA_REL_ "NodeMsgAccess" BU_BO_REL_ Sensor 400 2;
BA_REL_ "NodeSigAccess" BU_SG_REL_ Sensor SG_ 400 Status 1;

